# Kalshi API credentials — only needed for authenticated (portfolio/trading) endpoints.
# Series/event/market discovery works with no credentials at all.
# Generate a key pair at https://kalshi.com/account/profile (API Keys section);
# the private key is shown once, so save the .pem immediately.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# Explicit environment selector used by the live safety gate. Production is the
# default; use demo/sandbox to ensure live enablement is rejected.
KALSHI_ENVIRONMENT=production
KALSHI_PRODUCTION_BASE_URL=https://external-api.kalshi.com/trade-api/v2
KALSHI_DEMO_BASE_URL=https://external-api.demo.kalshi.co/trade-api/v2
# Optional backwards-compatible override. Leave empty in normal operation so
# the environment-specific URL above is authoritative.
KALSHI_BASE_URL=
# Optional Kalshi subaccount number. Omit for the primary account.
KALSHI_SUBACCOUNT=

# Supabase Postgres connection string. Find it in your Supabase project at
# Project Settings -> Database -> Connection string (URI format). Add it directly
# to your local .env, not in chat — this file is gitignored, so it never leaves
# your machine. Without this set, the dashboard falls back to sample data.
DATABASE_URL=
# CA cert for the DB connection, if your provider requires SSL verification.
# Store the actual file under a gitignored path (e.g. certs/), never commit it.
DATABASE_SSL_CA_FILE=

# NOAA Climate Data Online API token — independent ground-truth cross-check
# for Kalshi's own settlement data (scripts/validate_against_noaa.py, see
# weather/noaa_cdo.py). Free, email-based, arrives instantly:
# https://www.ncdc.noaa.gov/cdo-web/token
NOAA_CDO_TOKEN=

# Supabase project URL/service key — not currently used by any code here
# (DATABASE_URL covers everything today via plain Postgres access). Fill in
# if/when something needs the Supabase SDK directly (e.g. Storage, Auth).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Redis — used only by the backtest harness (backtest/cache.py) to cache
# collect_rows() results. Settled-market and historical-forecast data for a
# past date range never changes, so re-running a backtest to test a model
# change doesn't need to re-page through months of Kalshi history and
# re-fetch Open-Meteo's archive every time. Optional: everything falls back
# to an uncached fetch if this isn't set or Redis is unreachable.
REDIS_URL=
REDIS_KEY_PREFIX=kalshi-prediction-market
# Backtest cache entries use a longer TTL than this (the data is immutable,
# see above) — this default is for any other, more time-sensitive caching
# that might get added later.
REDIS_DEFAULT_TTL_SECONDS=300

# Frozen real-trading-readiness evidence collection. Leave disabled until the
# current db/schema.sql is deployed and artifacts/trading_readiness/
# candidate_freeze_manifest.json and artifacts/professional_trader/
# strategy_freeze_manifest.json have been generated. When enabled, the existing
# price-feed service records orderbook/trade/lifecycle/fill evidence, and the
# existing pipeline records prospective professional paper decisions and their
# append-only journal. Neither submits an order.
FORWARD_EVIDENCE_ENABLED=0
READINESS_MIN_CALENDAR_DAYS=60
READINESS_MIN_INDEPENDENT_EVENTS=100
READINESS_MIN_SETTLED_TRADES=100
READINESS_MIN_CITIES=5
READINESS_MIN_FORECAST_HORIZONS=2
READINESS_MAX_CALIBRATION_GAP=0.05
READINESS_MAX_ORDERBOOK_AGE_SECONDS=30
READINESS_MAX_SOURCE_RECEIPT_DELAY_SECONDS=10
READINESS_ORDERBOOK_DEPTH_LEVELS=100
READINESS_INTENDED_QUANTITY=1
READINESS_MAX_DRAWDOWN_DOLLARS=3

# Position sizing (sizing/kelly.py) — both are risk-tolerance choices, not
# derived values. See that module's docstring for the reasoning behind the
# defaults. KELLY_FRACTION is the multiplier on theoretical full-Kelly (0.25 =
# quarter-Kelly); MAX_EVENT_EXPOSURE caps total recommended stake across one
# event's correlated brackets, as a fraction of bankroll. Kalshi's own
# ~$25k-per-market position limit is applied separately and isn't configurable
# here (see KALSHI_POSITION_LIMIT_USD in sizing/kelly.py).
KELLY_FRACTION=0.25
MAX_EVENT_EXPOSURE=0.15

# Paper-trading bot risk controls (paper_trading/engine.py — the full set of
# PAPER_TRADING_* knobs and their reasoning lives there; these two are the
# cross-correlation and take-profit controls). All optional; unset uses the
# in-code defaults shown.
#
# PAPER_TRADING_MAX_DAY_EXPOSURE caps total NEW exposure per target date across
# every city, as a fraction of total bankroll — the correlated-night cap the
# per-event MAX_EVENT_EXPOSURE above can't see (one weather pattern moves many
# cities the same way at once; this is what the 0/57 wipeout needed). Default
# 0.35.
PAPER_TRADING_MAX_DAY_EXPOSURE=0.35
# PAPER_TRADING_TAKE_PROFIT_FRACTION sells a winning position early once its
# realizable gain (after the exit fee) reaches this fraction of cost basis,
# even if the model's edge would still hold it. Off by default (0.0): it trades
# expected value for lower variance, a deliberate risk-preference choice, so
# it's opt-in. E.g. 0.5 = bank a position once it's up 50% of what it cost.
PAPER_TRADING_TAKE_PROFIT_FRACTION=0.0

# Push notifications (notify/pushover.py, scripts/send_notifications.py) —
# one push per bracket the first time it becomes actionable each day, to
# your phone and/or Mac. Sign up at https://pushover.net, install the app(s),
# then create an "Application" in the dashboard for APP_TOKEN and copy your
# account's User Key. Small one-time cost per platform after a trial period.
# Without both set, scripts/send_notifications.py just skips silently.
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=

# Dashboard login (dashboard/app.py) — a numeric-only passcode gate in front
# of the whole app (in addition to, not instead of, the droplet's nginx Basic
# Auth). PASSCODES is a comma-separated list of valid 6-digit codes; any one
# of them logs in. FLASK_SECRET_KEY signs the session cookie — generate with
# `python3 -c "import secrets; print(secrets.token_hex(32))"`; changing it
# logs everyone out.
PASSCODES=
FLASK_SECRET_KEY=
