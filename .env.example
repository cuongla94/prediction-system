# Kalshi API credentials — only needed for authenticated (portfolio/trading) endpoints.
# Series/event/market discovery works with no credentials at all.
# Generate a key pair at https://kalshi.com/account/profile (API Keys section);
# the private key is shown once, so save the .pem immediately.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# Defaults to Kalshi production. Swap to the demo environment to test without real
# funds: https://demo-api.kalshi.co/trade-api/v2
KALSHI_BASE_URL=https://external-api.kalshi.com/trade-api/v2

# Supabase Postgres connection string. Find it in your Supabase project at
# Project Settings -> Database -> Connection string (URI format). Add it directly
# to your local .env, not in chat — this file is gitignored, so it never leaves
# your machine. Without this set, the dashboard falls back to sample data.
DATABASE_URL=
