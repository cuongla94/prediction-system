# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Secrets and local config
.env
*.pem
*.crt
*.key
*.ca
secrets/
certs/
.claude/settings.local.json

# Live fitted calibration, written by the weekly recalibration cron. Untracked
# ON PURPOSE and not an oversight: the droplet's deploy does `git reset --hard`,
# so a refit written to a tracked file would be silently reverted by the next
# push to main. weather/calibration_params.py stays the committed baseline and
# this overrides it at runtime. See weather/calibration_override.py.
weather/calibration_params_fitted.json

# Data
*.db
*.sqlite3

# Logs (scheduler cron output)
logs/*.log

# Editor/OS
.DS_Store
.idea/
.vscode/

# Test/tooling
.pytest_cache/
.ruff_cache/

# Audit reports (scripts/run_audit.py). Generated artefacts, and they name
# internal paths, IPs and access patterns — not for a public repo.
logs/audit/
